# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create via @BotFather → /newbot
# Generate a random secret: openssl rand -hex 32
# Register webhook WITH secret:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=<APP_URL>/api/telegram/webhook&secret_token=<SECRET>
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=YourBotUsername
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# ─── Google Gemini AI (free tier, AI search feature) ─────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
# Leave empty to disable the AI search button
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# ─── Web Push / VAPID keys ────────────────────────────────────────────────────
# Generate once: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
# NEXT_PUBLIC_ key is safe to expose; VAPID_PRIVATE_KEY is server-only
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── App URL ──────────────────────────────────────────────────────────────────
# Update to your Vercel URL after first deploy, then redeploy
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Vercel deployment steps ──────────────────────────────────────────────────
# 1. Push repo to GitHub
# 2. Import project at vercel.com/new
# 3. Add all env vars above in Vercel → Settings → Environment Variables
# 4. Deploy — Vercel auto-detects Next.js
# 5. Set NEXT_PUBLIC_APP_URL to https://your-app.vercel.app and redeploy
# 6. Register Telegram webhook:
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://your-app.vercel.app/api/telegram/webhook"
