        Math.cos((rLat * Math.PI) / 180) * Math.cos((parsed.data.delivery_lat * Math.PI) / 180) * Math.sin(dLng / 2) ** 2;
      const distanceKm = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
